NURSE_TOKEN=precare-dev-token-2026
# PR35 follow-up: guards POST /escalations/vision-report (a stateless,
# unauthenticated-by-default write that would otherwise let anyone who
# can reach the API flood the nurse dashboard with fabricated fall-risk
# alerts -- see backend/core/config.py's Settings.robot_token docstring.
ROBOT_TOKEN=precare-dev-robot-token-2026
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:8502

# Optional but recommended if you'll touch any ML feature (speech
# recognition, embedding/LLM classification fallbacks, pose model
# download) -- all of them pull model weights from Hugging Face on
# first use. Unauthenticated (anonymous) requests share a low, easily
# exhausted rate limit; a free account's read-only token raises it
# substantially. Get one at https://huggingface.co/settings/tokens
# (Read permission is enough -- this project never uploads anything).
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
 
# Optional. If unset, the backend falls back to a local SQLite file
# (data/precare.db) -- no setup needed for `pytest` or a quick local run.
# Set this to point at the PostgreSQL instance started by
# `docker-compose up` instead:
# DATABASE_URL=postgresql+psycopg2://precare:precare@localhost:5432/precare
 
